{
  "name": "ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:ui": "npm run dev --workspace=packages/ui",
    "storybook": "npm run storybook --workspace=packages/ui",
    "storybook:app-one": "npm run storybook --workspace=apps/app-one",
    "storybook:app-two": "npm run storybook --workspace=apps/app-two",
    "dev:app-one": "npm run dev --workspace=apps/app-one",
    "dev:app-two": "npm run dev --workspace=apps/app-two",
    "test": "npm run test --workspaces --if-present"
  }
}
